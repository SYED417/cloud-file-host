# ── Cloud File Host – environment variable template ──────────────────────────
#
# 1. Copy this file:   copy .env.example .env          (Windows CMD)
#                      Copy-Item .env.example .env      (PowerShell)
#                      cp .env.example .env             (Linux / Mac)
#
# 2. Fill in the real values below.
# 3. NEVER commit the .env file to git (it contains secrets).
# ─────────────────────────────────────────────────────────────────────────────

# AWS IAM credentials (create an IAM user with S3 permissions)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# The AWS region your S3 bucket lives in (e.g. eu-north-1, us-east-1)
AWS_DEFAULT_REGION=eu-north-1

# Exact name of your S3 bucket
S3_BUCKET_NAME=your-bucket-name-here

# Random secret used to sign Flask session cookies – generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_a_long_random_string
# Strict CORS allow-list for the JSON API. Comma-separated, NO wildcard.
# Set this to your exact Vercel domain(s) in Render's environment settings.
#   e.g. ALLOWED_ORIGINS=https://your-app.vercel.app
# If unset, ALL cross-origin API requests are rejected (fail-closed).
ALLOWED_ORIGINS=https://your-app.vercel.app
